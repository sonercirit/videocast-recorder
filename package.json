{
  "name": "videocast-recorder",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "format": "prettier . --write --ignore-unknown",
    "format:check": "prettier . --check --ignore-unknown",
    "auth:schema:generate": "better-auth generate --config ./src/auth.config.ts --output ./src/db/auth-schema.gen.ts --yes",
    "db:generate": "npm run auth:schema:generate && drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply videocast-recorder --local",
    "db:migrate:remote": "wrangler d1 migrations apply videocast-recorder --remote"
  },
  "dependencies": {
    "better-auth": "latest",
    "drizzle-orm": "latest",
    "hono": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@cloudflare/workers-types": "latest",
    "drizzle-kit": "latest",
    "prettier": "3.8.3",
    "typescript": "latest",
    "wrangler": "latest"
  }
}
